{
    "name": "webfactory/slimdump",
    "description": "slimdump is a little tool to help you creating dumps of large MySQL-databases.",
    "minimum-stability": "stable",
    "license": "MIT",
    "authors": [
        {
            "name": "webfactory GmbH",
            "email": "info@webfactory.de",
            "homepage": "http://www.webfactory.de",
            "role": "Developer"
        }
    ],
    "bin": [
        "bin/slimdump"
    ],
    "require": {
        "php": ">= 8.1",
        "ext-SimpleXML": "*",
        "ext-libxml": "*",
        "ext-pdo": "*",
        "doctrine/dbal": "^3.3 || ^4.0",
        "doctrine/event-manager": "^1.0 || ^2.0",
        "fakerphp/faker": "^1.14",
        "symfony/console": "^4.0 || ^5.0 || ^6.0 || ^7.0 || ^8.0",
        "symfony/service-contracts": "^2.1.2 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Webfactory\\Slimdump\\": "src/Webfactory/Slimdump"
        }
    },
    "config": {
        "sort-packages": true
    }
}
